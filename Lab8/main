#include "mbed.h"
#include "arm_book_lib.h"
#include "lcd.h"
#include "FATFileSystem.h"
#include "SDBlockDevice.h"
#include <cstdio>

#define FILTER_COUNT 100
#define STEP_DELAY 10

AnalogIn potPin(A0);
AnalogIn tempPin(A1);
AnalogIn gasPin(A2);
PwmOut audioSiren(D9);

DigitalOut r1(D0), r2(D1), r3(D2), r4(D3);
DigitalIn c1(D4, PullUp), c2(D5, PullUp), c3(D6, PullUp), c4(D7, PullUp);

SDBlockDevice sd(D11, D12, D13, D10);
FATFileSystem fs("sd");

UnbufferedSerial terminalLog(USBTX, USBRX, 115200);

float tempHistory[FILTER_COUNT];
int historyIdx = 0;

int storedAlarms[5] = {0, 0, 0, 0, 0};
int alarmCounter = 0;

char keysLayout[4][4] = {
    {'1','2','3','A'},
    {'4','5','6','B'},
    {'7','8','9','C'},
    {'*','0','#','D'}
};

char codeBuffer[3] = {'\0', '\0', '\0'};
int codeLength = 0;
int isSirenTriggered = 0;
char activeDisplayMode = 'A';

float calcCelsiusTemp() {
    tempHistory[historyIdx] = tempPin.read();
    historyIdx++;
    if (historyIdx >= FILTER_COUNT) {
        historyIdx = 0;
    }
    float sum = 0.0;
    for (int idx = 0; idx < FILTER_COUNT; idx++) {
        sum += tempHistory[idx];
    }
    return ((sum / FILTER_COUNT) * 330.0);
}

char checkKeypad() {
    DigitalOut* rowPins[4] = {&r1, &r2, &r3, &r4};
    DigitalIn* colPins[4] = {&c1, &c2, &c3, &c4};
    
    for (int i = 0; i < 4; i++) {
        r1 = r2 = r3 = r4 = 1;
        *rowPins[i] = 0;
        
        for (int j = 0; j < 4; j++) {
            if (!(*colPins[j])) {
                delay(40);
                if (!(*colPins[j])) {
                    while (!(*colPins[j]));
                    return keysLayout[i][j];
                }
            }
        }
    }
    return '\0';
}

void writeSdLog(const char* type, int val) {
    sd.init();
    fs.mount(&sd);
    FILE* f = fopen("/sd/log.txt", "a");
    if (f != NULL) {
        fprintf(f, "Alert: %s = %d\n", type, val);
        fclose(f);
    }
    fs.unmount();
    sd.deinit();
}

void readSdLog() {
    sd.init();
    fs.mount(&sd);
    FILE* f = fopen("/sd/log.txt", "r");
    if (f != NULL) {
        terminalLog.write("--- SD Card Log Content ---\r\n", 29);
        char ch;
        while ((ch = fgetc(f)) != EOF) {
            if (ch == '\n') {
                terminalLog.write("\r\n", 2);
            } else {
                terminalLog.write(&ch, 1);
            }
        }
        terminalLog.write("--- End of SD Log ---\r\n", 23);
        fclose(f);
    } else {
        terminalLog.write("No Log File Found\r\n", 19);
    }
    fs.unmount();
    sd.deinit();
}

int main() {
    audioSiren.write(0.0); lcd_init();
    
    for (int idx = 0; idx < FILTER_COUNT; idx++) {
        tempHistory[idx] = tempPin.read();
    }

    lcd_clear(); lcd_set(0, 0); lcd_print("Enter Code to");
    lcd_set(0, 1); lcd_print("Deactivate Alarm");

    int reportTick = 0;
    int alarmCooldownCounter = 0;

    while (true) {
        float currentTemp = calcCelsiusTemp();
        float currentPot = potPin.read();
        float dynamicLimit = currentPot * 100.0;

        float rawGas = gasPin.read();
        float scaledGas = rawGas * 100.0;

        char genericKey = checkKeypad();

        if (alarmCooldownCounter > 0) {
            alarmCooldownCounter--;
        }

        if (genericKey == 'A' || genericKey == 'B') {
            activeDisplayMode = genericKey;
            reportTick = 100;
        }

        if (genericKey == '*') {
            readSdLog();
        }

        int gasFault = (scaledGas > dynamicLimit) ? 1 : 0;
        int tempFault = (currentTemp > dynamicLimit) ? 1 : 0;

        int triggerAlarm = 0;
        if (activeDisplayMode == 'A' && tempFault) triggerAlarm = 1;
        if (activeDisplayMode == 'B' && gasFault) triggerAlarm = 1;

        if (triggerAlarm && alarmCooldownCounter == 0) {
            isSirenTriggered = 1;
            storedAlarms[alarmCounter % 5] = (int)currentTemp;
            alarmCounter++;
            
            audioSiren.period(1.0 / 2000.0);
            audioSiren.write(0.5);
            
            lcd_clear(); lcd_set(0, 0);
            if (activeDisplayMode == 'A') {
                lcd_print("TEMP WARNING!"); lcd_set(0, 1); lcd_print("EXCEEDED LIMIT");
                char alertMsg[40]; sprintf(alertMsg, "Alert Logged: Temp = %d C\r\n", (int)currentTemp);
                terminalLog.write(alertMsg, strlen(alertMsg));
                writeSdLog("Temp", (int)currentTemp);
            } else {
                lcd_print("GAS WARNING!"); lcd_set(0, 1); lcd_print("LEAK DETECTED");
                char alertMsg[40]; sprintf(alertMsg, "Alert Logged: Gas = %d ppm\r\n", (int)scaledGas);
                terminalLog.write(alertMsg, strlen(alertMsg));
                writeSdLog("Gas", (int)scaledGas);
            }
            
            delay(1500); lcd_clear(); lcd_set(0, 0); lcd_print("Enter Code:"); codeLength = 0;
            int innerPrintTick = 0;

            while (isSirenTriggered == 1) {
                float lockTemp = calcCelsiusTemp();
                float lockPot = potPin.read();
                float lockLimit = lockPot * 100.0;
                float lockGas = gasPin.read() * 100.0;

                innerPrintTick++;
                if (innerPrintTick >= 100) {
                    int tW = (int)lockTemp;
                    int tF = (int)((lockTemp - tW) * 10.0);
                    if (tF < 0) tF = -tF;

                    int lW = (int)lockLimit;
                    int lF = (int)((lockLimit - lW) * 10.0);
                    if (lF < 0) lF = -lF;

                    char streamBuffer[150];
                    sprintf(streamBuffer, "ALERT ACTIVE | Mode: %c | Temp: %d.%d C | Gas: %d | Limit: %d.%d\r\n", 
                            activeDisplayMode, tW, tF, (int)lockGas, lW, lF);
                    terminalLog.write(streamBuffer, strlen(streamBuffer));
                    innerPrintTick = 0;
                }

                char secureKey = checkKeypad();
                if (secureKey != '\0') {
                    if (secureKey == '*') {
                        if (codeLength == 3 && codeBuffer[0] == '1' && codeBuffer[1] == '2' && codeBuffer[2] == '3') {
                            isSirenTriggered = 0;
                            audioSiren.write(0.0);
                            activeDisplayMode = 'A';
                            codeLength = 0;
                            
                            lcd_clear(); lcd_set(0, 0); lcd_print("Code Correct");
                            delay(1000); lcd_clear(); lcd_set(0, 0); lcd_print("Enter Code to");
                            lcd_set(0, 1); lcd_print("Deactivate Alarm");
                            
                            for (int idx = 0; idx < FILTER_COUNT; idx++) {
                                tempHistory[idx] = tempPin.read();
                            }
                            alarmCooldownCounter = 300;
                        } else {
                            lcd_clear(); lcd_set(0, 0); lcd_print("Wrong Code!"); delay(1000);
                            lcd_clear(); lcd_set(0, 0); lcd_print("Enter Code:"); codeLength = 0;
                        }
                    } else if (secureKey != '#' && codeLength < 3) {
                        codeBuffer[codeLength] = secureKey;
                        codeLength++;
                        lcd_set(codeLength - 1, 1); lcd_print("*");
                    }
                }
                delay(STEP_DELAY);
            }
        } else {
            audioSiren.write(0.0);

            if (genericKey == '#') {
                terminalLog.write("--- Temperature Event Log ---\r\n", 31);
                for (int idx = 0; idx < 5; idx++) {
                    char outputLog[40];
                    sprintf(outputLog, "Log %d: %d C\r\n", idx + 1, storedAlarms[idx]);
                    terminalLog.write(outputLog, strlen(outputLog));
                }
            }

            reportTick++;
            if (reportTick >= 100) {
                int wTemp = (int)currentTemp;
                int fTemp = (int)((currentTemp - wTemp) * 10.0);
                if (fTemp < 0) fTemp = -fTemp;

                int wLimit = (int)dynamicLimit;
                int fLimit = (int)((dynamicLimit - wLimit) * 10.0);
                if (fLimit < 0) fLimit = -fLimit;

                if (activeDisplayMode == 'B') {
                    lcd_clear(); lcd_set(0, 0); char gStr[16]; sprintf(gStr, "Gas Level: %d", (int)scaledGas);
                    lcd_print(gStr); lcd_set(0, 1); lcd_print("Gas Status: OK");
                } else if (activeDisplayMode == 'A') {
                    lcd_clear(); lcd_set(0, 0); char tStr[16]; sprintf(tStr, "Temp: %d.%d C", wTemp, fTemp);
                    lcd_print(tStr); lcd_set(0, 1); char hStr[16]; sprintf(hStr, "Thresh: %d.%d C", wLimit, fLimit);
                    lcd_print(hStr);
                }

                char regularBuffer[160];
                sprintf(regularBuffer, "System Normal | Mode: %c | Temp = %d.%d C | Gas Level = %d | Limit = %d.%d\r\n", 
                        activeDisplayMode, wTemp, fTemp, (int)scaledGas, wLimit, fLimit);
                terminalLog.write(regularBuffer, strlen(regularBuffer));
                reportTick = 0;
            }
        }

        delay(STEP_DELAY);
    }
}
